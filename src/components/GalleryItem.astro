---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
    image: string | ImageMetadata | { src: string; width: number; height: number; format: string };
    alt?: string;
}

const { image, alt = "Tattoo work" } = Astro.props;
---

<div class="gallery-item">
    <Image src={image as any} alt={alt} />
    <div class="gallery-overlay">View Details</div>
</div>

<style>
    .gallery-item {
        aspect-ratio: 1;
        overflow: hidden;
        position: relative;
        cursor: pointer;
    }

    .gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        filter: brightness(0.8);
    }

    .gallery-item:hover img {
        transform: scale(1.1);
        filter: brightness(1);
    }

    .gallery-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: 0.3s;
        font-family: var(--font-heading);
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .gallery-item:hover .gallery-overlay {
        opacity: 1;
    }
</style>
