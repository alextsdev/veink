---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
    name: string;
    style: string;
    image: string | ImageMetadata | { src: string; width: number; height: number; format: string };
    description: string;
}

const { name, style, image, description } = Astro.props;
---

<div class="artist-card" data-description={description} data-style={style}>
    <div class="artist-img-wrapper">
        <Image src={image as any} alt={name} />
    </div>
    <h3>{name}</h3>
    <span>{style}</span>
</div>

<style>
    .artist-card {
        text-align: center;
        cursor: pointer;
    }

    .artist-img-wrapper {
        aspect-ratio: 3/4;
        background: #151515;
        margin-bottom: 20px;
        position: relative;
        overflow: hidden;
    }

    .artist-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(1);
        transition: 0.5s;
    }

    .artist-card:hover img {
        filter: grayscale(0);
        transform: scale(1.05);
    }

    .artist-card h3 {
        font-size: 1.5rem;
        margin: 0;
    }

    .artist-card span {
        color: var(--accent);
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 2px;
    }
</style>
