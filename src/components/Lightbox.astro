---

<div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightbox-close">&times;</button>
    <div class="lightbox-content">
        <img src="" alt="Enlarged work" id="lightbox-img" />
    </div>
</div>

<style>
    .lightbox {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.95);
        z-index: 2000;
        display: none;
        justify-content: center;
        align-items: center;
        backdrop-filter: blur(10px);
        cursor: zoom-out;
    }

    .lightbox.active {
        display: flex;
        animation: fadeIn 0.4s ease;
    }

    .lightbox-content {
        max-width: 90%;
        max-height: 90vh;
        position: relative;
    }

    .lightbox img {
        max-width: 100%;
        max-height: 90vh;
        object-fit: contain;
        border: 1px solid var(--border);
        box-shadow: 0 0 50px rgba(0, 0, 0, 0.5);
    }

    .lightbox-close {
        position: absolute;
        top: -40px;
        right: 0;
        color: white;
        font-size: 2rem;
        cursor: pointer;
        background: none;
        border: none;
        font-family: var(--font-body);
    }
</style>
