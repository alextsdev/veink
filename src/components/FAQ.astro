---
const faqs = [
    {
        question: "How do I book an appointment?",
        answer: "You can book through our inquiry form or directly via Instagram. A deposit is required to confirm your date.",
    },
    {
        question: "Does getting a tattoo hurt?",
        answer: "Pain is subjective and depends on the body area. Our artists work to make the experience as comfortable as possible.",
    },
    {
        question: "What aftercare should I follow?",
        answer: "We'll provide a detailed guide after your session. Basically: gentle cleaning, hydration, and no sun or swimming for 2 weeks.",
    },
    {
        question: "Can I bring my own design?",
        answer: "Of course! Our artists can also refine it to better fit your skin and ensure the best long-term result.",
    },
];
---

<section class="faq" id="faq">
    <div class="section-header">
        <span class="subtitle">Common Doubts</span>
        <h2>Frequently Asked Questions</h2>
    </div>

    <div class="faq-container">
        {
            faqs.map((faq, index) => (
                <div class="faq-item">
                    <button class="faq-question">
                        <span>{faq.question}</span>
                        <span class="icon">+</span>
                    </button>
                    <div class="faq-answer">
                        <p>{faq.answer}</p>
                    </div>
                </div>
            ))
        }
    </div>
</section>

<style>
    .faq {
        background: #050505;
    }

    .faq-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .faq-item {
        border-bottom: 1px solid var(--border);
    }

    .faq-question {
        width: 100%;
        padding: 30px 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: none;
        border: none;
        color: white;
        cursor: pointer;
        text-align: left;
        font-family: var(--font-body);
        font-size: 1.1rem;
        transition: 0.3s;
    }

    .faq-question:hover {
        color: var(--accent);
    }

    .faq-question .icon {
        font-size: 1.5rem;
        transition: 0.4s;
    }

    .faq-item.active .icon {
        transform: rotate(45deg);
        color: var(--accent);
    }

    .faq-answer {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .faq-item.active .faq-answer {
        max-height: 200px;
    }

    .faq-answer p {
        padding-bottom: 30px;
        color: var(--text-muted);
        line-height: 1.8;
        margin: 0;
    }
</style>

<script>
    const faqItems = document.querySelectorAll(".faq-item");

    faqItems.forEach((item) => {
        const question = item.querySelector(".faq-question");
        question?.addEventListener("click", () => {
            faqItems.forEach((otherItem) => {
                if (otherItem !== item) otherItem.classList.remove("active");
            });
            item.classList.toggle("active");
        });
    });
</script>
